{
  "name": "jsray",
  "version": "0.0.1-internal.2",
  "private": true,
  "description": "JavaScript-native code rendering kernel with 22-class token semantics and pluggable themes.",
  "author": "Eric Liu <eric@jsray.org>",
  "main": "dist/jsray.js",
  "style": "dist/jsray.css",
  "types": "types/jsray.d.ts",
  "files": [
    "assets/brand",
    "dist",
    "types",
    "tokens.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "sh build.sh",
    "check:versions": "node tools/check-versions.mjs",
    "test": "node --test tests/*.mjs",
    "demo": "echo 'Open demo/index.html in a browser, or serve the project root and visit /demo/'",
    "sync:integrations": "sh tools/sync-integrations.sh"
  },
  "keywords": [
    "jsray",
    "code-rendering",
    "syntax-highlighter",
    "code-highlighter",
    "javascript-native",
    "zero-dependency",
    "developer-tools",
    "themes"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://jsray.org"
}
